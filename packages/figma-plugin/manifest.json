{
  "name": "nexui-sync",
  "id": "com.nexui.sync",
  "api": "1.0.0",
  "main": "dist/code.js",
  "ui": "dist/ui.html",
  "uiEntry": "dist/ui.js",
  "editorType": ["figma"],
  "networkAccess": {
    "allowedDomains": ["raw.githubusercontent.com", "api.github.com"]
  },
  "documentAccess": "dynamic-page",
  "parameters": [
    {
      "name": "github-token",
      "type": "string",
      "description": "GitHub Personal Access Token"
    }
  ]
}
