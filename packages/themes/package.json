{
  "name": "@nexui/themes",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "sideEffects": ["./dist/nexui-variables.css"],
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./dist/nexui-variables.css",
    "./variables.css": "./dist/nexui-variables.css",
    "./tokens.json": "./dist/tokens.style-dictionary.json"
  },
  "scripts": {
    "prebuild": "node ./scripts/prebuild.mjs",
    "build": "pnpm run prebuild && tsup && node ./scripts/postbuild.mjs",
    "dev": "pnpm run prebuild && tsup --watch",
    "lint": "pnpm run prebuild && eslint .",
    "test": "pnpm run prebuild && vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "eslint": "^9.21.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
